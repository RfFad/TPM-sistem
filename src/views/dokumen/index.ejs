<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Prosedur Mutu - Penerimaan Karyawan</title>
  <link rel="stylesheet" href="style.css">
</head>
<body>
    <style>
        body {
  font-family: "Times New Roman", serif;
  background: #f4f4f4;
}

.container {
  width: 900px;
  margin: 20px auto;
  background: white;
  padding: 15px;
  border: 1px solid #000;
}

/* HEADER */
.doc-header {
  width: 100%;
  border-collapse: collapse;
  margin-bottom: 15px;
}

.doc-header td {
  border: 1px solid #000;
  vertical-align: middle;
}

.logo {
  width: 25%;
  text-align: center;
  padding: 10px;
}

.logo img {
  max-width: 80px;
}

.company-name {
  font-size: 12px;
  font-weight: bold;
}

.title {
  width: 45%;
  text-align: center;
}

.doc-title {
  font-weight: bold;
  font-size: 16px;
}

.doc-subtitle {
  font-weight: bold;
  font-size: 14px;
}

.doc-info {
  width: 30%;
  font-size: 12px;
}

.doc-info table {
  width: 100%;
}

/* CONTENT */
.doc-content {
  width: 100%;
  border-collapse: collapse;
}

.section-number {
  width: 5%;
  font-weight: bold;
  vertical-align: top;
  margin-top: 50px;
}

.section-title {
  font-weight: bold;
}

.section-text {
  padding: 8px 0 12px 0;
  text-align: justify;
}

.boxed-text {
  border: 1px solid #000;
  padding: 10px;
  margin-bottom: 10px;
}

.inner-table {
  width: 100%;
  border-collapse: collapse;
}

.inner-table td {
  padding: 4px;
  vertical-align: top;
}

.term {
  width: 25%;
  font-weight: bold;
}

    </style>

<div class="container">

  <!-- HEADER DOKUMEN -->
  <table class="doc-header">
    <tr>
      <td class="logo">
        <img src="/login-bg/logo.png" alt="Logo Perusahaan">
        <div class="company-name">
          PT. TRIVINDO PRIMA MANDIRI
        </div>
      </td>

      <td class="title">
        <div class="doc-title">PROSEDUR MUTU</div>
        <div class="doc-subtitle">PENERIMAAN KARYAWAN</div>
      </td>

      <td class="doc-info">
        <table>
          <tr><td>No Dokumen</td><td>: TPM-PM-HRD-01</td></tr>
          <tr><td>Departemen</td><td>: HRD & GA</td></tr>
          <tr><td>Revisi</td><td>: 02</td></tr>
          <tr><td>Tanggal</td><td>: 21 Agustus 2025</td></tr>
          <tr><td>Hal</td><td>: 1 of 4</td></tr>
        </table>
      </td>
    </tr>
  </table>

  <!-- ISI DOKUMEN -->
  <table class="doc-content">

    <tr>
      <td class="section-number">1.</td>
      <td class="section-title">TUJUAN</td>
    </tr>
    <tr>
      <td></td>
      <td class="section-text" contenteditable="true" data-field="tujuan">
        <%= item.tujuan %>
      </td>

    </tr>

    <tr>
      <td class="section-number">2.</td>
      <td class="section-title">REFERENSI</td>
    </tr>
    <tr>
      <td></td>
      <%
  const parts = item.referensi.split('\n\n');
%>

<td class="boxed-text" contenteditable="true" data-field="referensi">
  <strong><%= parts[0] %></strong><br><br>
  <%= parts.slice(1).join('\n\n') %>
</td>


    </tr>

    <tr>
      <td class="section-number">3.</td>
      <td class="section-title">RUANG LINGKUP</td>
    </tr>
    <tr>
      <td></td>
     <td class="section-text" contenteditable="true" data-field="ruang_lingkup">
  <%= item.ruang_lingkup %>
    </td>

    </tr>

    <tr>
      <td class="section-number">4.</td>
      <td class="section-title">DAFTAR ISTILAH</td>
    </tr>

    <tr>
      <td></td>
      <td>
       <table class="inner-table">
    <% daftar.forEach((daftar, index) => { %>
        <tr>
            <td class="term">
                4.<%= index + 1 %> <%= daftar.nama_istilah %>
            </td>
            <td>
                : <%= daftar.deskripsi %>
            </td>
        </tr>
    <% }) %>
</table>
      </td>
    </tr>

  </table>


</div>
<div class="update-wrapper">
  <button id="btnUpdate" class="btn-update">
    💾 Update Dokumen
  </button>
</div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  const referensiEl = document.querySelector('[data-field="referensi"]');

// clone agar tidak mengubah DOM asli
const clone = referensiEl.cloneNode(true);

// ambil strong
const strongText = clone.querySelector('strong')?.innerText || '';

// hapus strong dari clone
clone.querySelector('strong')?.remove();

// ambil isi setelah strong
const isiReferensi = clone.innerText.trim();

// gabungkan kembali (1 string, aman ke DB)
const referensiFinal = strongText + '\n\n' + isiReferensi;

document.getElementById('btnUpdate').addEventListener('click', () => {

  Swal.fire({
    title: 'Simpan Perubahan?',
    text: 'Perubahan dokumen akan disimpan',
    icon: 'warning',
    showCancelButton: true,
    confirmButtonText: 'Ya, Simpan',
    cancelButtonText: 'Batal'
  }).then((result) => {

    if (!result.isConfirmed) return;

    const data = {
      tujuan: document.querySelector('[data-field="tujuan"]').innerText.trim(),
      referensi: document.querySelector('[data-field="referensi"]').innerText.trim(),
      ruang_lingkup: document.querySelector('[data-field="ruang_lingkup"]').innerText.trim()
    };

    fetch('/dokumen/update', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    })
    .then(res => res.json())
    .then(res => {
      if (res.success) {
        Swal.fire('Berhasil!', 'Dokumen berhasil diperbarui', 'success');
      } else {
        Swal.fire('Gagal!', res.message, 'error');
      }
    })
    .catch(() => {
      Swal.fire('Error!', 'Terjadi kesalahan server', 'error');
    });

  });
});
</script>

</body>
</html>
