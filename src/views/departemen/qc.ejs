<%- include("../partials/header") %>
<%- include("../partials/sideNavbar") %>

<div class="content-wrapper">

  <!-- Header Section -->
  <section class="content-header">
    <div class="container-fluid">
      <div class="jumbotron bg-gradient-primary text-white shadow rounded">
        <h1 class="display-5 font-weight-bold">
          <i class="fas fa-check-circle"></i> Departemen Quality Control (QC)
        </h1>
        <p class="lead mt-3">
          Menjamin kualitas produk sesuai standar perusahaan dan kepuasan pelanggan melalui proses inspeksi dan pengendalian mutu yang sistematis.
        </p>
      </div>
    </div>
  </section>

  <!-- Tentang QC -->
  <section class="content">
    <div class="container-fluid">
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <h4 class="font-weight-bold mb-3 text-primary">
            Tentang Departemen QC
          </h4>
          <p style="text-align: justify;">
            Departemen Quality Control (QC) bertanggung jawab dalam memastikan seluruh produk yang diproduksi telah memenuhi standar kualitas yang ditetapkan perusahaan maupun pelanggan. 
            QC melakukan pemeriksaan bahan baku, proses produksi, hingga produk jadi dengan metode inspeksi visual maupun pengujian teknis.
          </p>
          <p style="text-align: justify;">
            Dengan sistem pengendalian mutu yang terstruktur, departemen QC membantu meminimalisir defect, meningkatkan efisiensi produksi, serta menjaga reputasi perusahaan di mata customer.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Work Instruction Section -->
  <section class="content mt-4">
    <div class="container-fluid">
      <div class="card shadow border-0">
        <div class="card-header bg-info text-white">
          <h5 class="mb-0">
            <i class="fas fa-book"></i> Work Instruction QC
          </h5>
        </div>
        <div class="card-body text-center">

          <!-- GANTI src DENGAN GAMBAR ANDA -->
          <img src="/images/work-instruction-qc.jpg" 
               class="img-fluid rounded shadow-sm mb-3"
               style="max-height:400px; object-fit:cover;">

          <p class="text-muted">
            Dokumen Work Instruction digunakan sebagai panduan standar dalam proses inspeksi dan pengujian produk.
          </p>

        </div>
      </div>
    </div>
  </section>

  <!-- Galeri Aktivitas QC -->
  <section class="content mt-4 pb-5">
    <div class="container-fluid">

      <h4 class="font-weight-bold text-primary mb-3">
        Aktivitas Quality Control
      </h4>

      <div class="row">

        <!-- Foto 1 -->
        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <img src="/images/qc-1.jpg" class="card-img-top" style="height:220px; object-fit:cover;">
            <div class="card-body">
              <h6 class="font-weight-bold">Inspection Process</h6>
              <p class="text-muted small">
                Pemeriksaan dimensi dan visual produk sebelum pengiriman.
              </p>
            </div>
          </div>
        </div>

        <!-- Foto 2 -->
        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <img src="/images/qc-2.jpg" class="card-img-top" style="height:220px; object-fit:cover;">
            <div class="card-body">
              <h6 class="font-weight-bold">Testing & Measurement</h6>
              <p class="text-muted small">
                Pengujian menggunakan alat ukur presisi untuk memastikan standar kualitas.
              </p>
            </div>
          </div>
        </div>

        <!-- Foto 3 -->
        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <img src="/images/qc-3.jpg" class="card-img-top" style="height:220px; object-fit:cover;">
            <div class="card-body">
              <h6 class="font-weight-bold">Quality Reporting</h6>
              <p class="text-muted small">
                Dokumentasi hasil inspeksi sebagai bagian dari sistem manajemen mutu.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</div>

<%- include("../partials/footer") %>