<%- include("../partials/header") %>
<%- include("../partials/sideNavbar") %>

<div class="content-wrapper">

  <!-- Header -->
  <section class="content-header">
    <div class="container-fluid">
      <div class="jumbotron bg-gradient-warning text-dark shadow rounded">
        <h1 class="display-5 font-weight-bold">
          <i class="fas fa-tools"></i> Departemen Mold Shop
        </h1>
        <p class="lead mt-3">
          Bertanggung jawab dalam pembuatan, perawatan, dan perbaikan mold untuk menjaga stabilitas proses produksi.
        </p>
      </div>
    </div>
  </section>

  <!-- Tentang Mold Shop -->
  <section class="content">
    <div class="container-fluid">
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <h4 class="font-weight-bold text-warning mb-3">Tentang Departemen Mold Shop</h4>
          <p style="text-align: justify;">
            Departemen Mold Shop berperan dalam pembuatan dan maintenance mold agar proses produksi berjalan lancar.
            Tim mold memastikan setiap mold dalam kondisi optimal untuk menghasilkan produk dengan presisi tinggi.
          </p>
          <p style="text-align: justify;">
            Dengan dukungan teknisi berpengalaman dan peralatan presisi, mold shop membantu mengurangi defect,
            memperpanjang umur mold, dan meningkatkan efisiensi produksi.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Work Instruction -->
  <section class="content mt-4">
    <div class="container-fluid">
      <div class="card shadow border-0">
        <div class="card-header bg-warning">
          <h5 class="mb-0"><i class="fas fa-book"></i> Work Instruction Mold Shop</h5>
        </div>
        <div class="card-body text-center">
          <img src="/images/work-instruction-mold.jpg" 
               class="img-fluid rounded shadow-sm mb-3"
               style="max-height:400px; object-fit:cover;">
          <p class="text-muted">
            Prosedur perawatan dan perbaikan mold untuk menjaga kualitas hasil produksi.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Aktivitas Mold Shop -->
  <section class="content mt-4 pb-5">
    <div class="container-fluid">
      <h4 class="font-weight-bold text-warning mb-3">Aktivitas Mold Shop</h4>

      <div class="row">

        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <img src="/images/mold-1.jpg" class="card-img-top" style="height:220px; object-fit:cover;">
            <div class="card-body">
              <h6 class="font-weight-bold">Mold Maintenance</h6>
              <p class="text-muted small">Perawatan rutin untuk menjaga presisi mold.</p>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <img src="/images/mold-2.jpg" class="card-img-top" style="height:220px; object-fit:cover;">
            <div class="card-body">
              <h6 class="font-weight-bold">Repair Process</h6>
              <p class="text-muted small">Perbaikan mold yang mengalami kerusakan.</p>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <img src="/images/mold-3.jpg" class="card-img-top" style="height:220px; object-fit:cover;">
            <div class="card-body">
              <h6 class="font-weight-bold">Precision Machining</h6>
              <p class="text-muted small">Proses machining untuk pembuatan mold baru.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</div>

<%- include("../partials/footer") %>