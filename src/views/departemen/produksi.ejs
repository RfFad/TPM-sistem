<%- include("../partials/header") %>
<%- include("../partials/sideNavbar") %>

<div class="content-wrapper">

  <!-- Header -->
  <section class="content-header">
    <div class="container-fluid">
      <div class="jumbotron bg-gradient-success text-white shadow rounded">
        <h1 class="display-5 font-weight-bold">
          <i class="fas fa-industry"></i> Departemen Produksi
        </h1>
        <p class="lead mt-3">
          Mengelola proses produksi secara efisien untuk menghasilkan produk berkualitas tinggi sesuai target perusahaan.
        </p>
      </div>
    </div>
  </section>

  <!-- Tentang Produksi -->
  <section class="content">
    <div class="container-fluid">
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <h4 class="font-weight-bold text-success mb-3">Tentang Departemen Produksi</h4>
          <p style="text-align: justify;">
            Departemen Produksi bertanggung jawab atas seluruh proses manufaktur mulai dari persiapan material,
            pengoperasian mesin, hingga memastikan output sesuai dengan planning dan standar kualitas.
          </p>
          <p style="text-align: justify;">
            Dengan sistem monitoring dan kontrol proses yang ketat, produksi berperan penting dalam menjaga efisiensi,
            meminimalkan downtime, serta memastikan pencapaian target harian dan bulanan.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Work Instruction -->
  <section class="content mt-4">
    <div class="container-fluid">
      <div class="card shadow border-0">
        <div class="card-header bg-success text-white">
          <h5 class="mb-0"><i class="fas fa-book"></i> Work Instruction Produksi</h5>
        </div>
        <div class="card-body text-center">
          <img src="/images/work-instruction-produksi.jpg" 
               class="img-fluid rounded shadow-sm mb-3"
               style="max-height:400px; object-fit:cover;">
          <p class="text-muted">
            Panduan kerja operator dalam menjalankan mesin dan proses produksi sesuai SOP.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Aktivitas Produksi -->
  <section class="content mt-4 pb-5">
    <div class="container-fluid">
      <h4 class="font-weight-bold text-success mb-3">Aktivitas Produksi</h4>

      <div class="row">

        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <img src="/images/produksi-1.jpg" class="card-img-top" style="height:220px; object-fit:cover;">
            <div class="card-body">
              <h6 class="font-weight-bold">Machine Operation</h6>
              <p class="text-muted small">Proses pengoperasian mesin produksi.</p>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <img src="/images/produksi-2.jpg" class="card-img-top" style="height:220px; object-fit:cover;">
            <div class="card-body">
              <h6 class="font-weight-bold">Assembly Process</h6>
              <p class="text-muted small">Perakitan komponen sesuai standar kerja.</p>
            </div>
          </div>
        </div>

        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <img src="/images/produksi-3.jpg" class="card-img-top" style="height:220px; object-fit:cover;">
            <div class="card-body">
              <h6 class="font-weight-bold">Production Monitoring</h6>
              <p class="text-muted small">Monitoring output dan pencapaian target produksi.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</div>

<%- include("../partials/footer") %>