<%- include("../partials/header") %>
<%- include("../partials/sideNavbar") %>

<div class="content-wrapper">

  <!-- Header Section -->
  <section class="content-header">
    <div class="container-fluid">
      <div class="jumbotron bg-gradient-danger text-white shadow rounded">
        <h1 class="display-5 font-weight-bold">
          <i class="fas fa-cogs"></i> Departemen Maintenance (MTN)
        </h1>
        <p class="lead mt-3">
          Menjaga stabilitas dan keandalan mesin produksi melalui sistem preventive dan corrective maintenance.
        </p>
      </div>
    </div>
  </section>

  <!-- Tentang MTN -->
  <section class="content">
    <div class="container-fluid">
      <div class="card shadow-sm border-0">
        <div class="card-body">
          <h4 class="font-weight-bold text-danger mb-3">
            Tentang Departemen Maintenance
          </h4>
          <p style="text-align: justify;">
            Departemen Maintenance (MTN) bertanggung jawab dalam memastikan seluruh mesin dan peralatan produksi 
            beroperasi secara optimal dan efisien. Tim maintenance melakukan kegiatan preventive maintenance 
            secara berkala untuk mencegah kerusakan, serta corrective maintenance ketika terjadi gangguan mesin.
          </p>
          <p style="text-align: justify;">
            Dengan sistem monitoring dan analisa downtime, MTN berperan penting dalam menjaga kelancaran proses 
            produksi, meminimalkan breakdown, serta meningkatkan umur pakai mesin dan peralatan produksi.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Work Instruction -->
  <section class="content mt-4">
    <div class="container-fluid">
      <div class="card shadow border-0">
        <div class="card-header bg-danger text-white">
          <h5 class="mb-0">
            <i class="fas fa-book"></i> Work Instruction Maintenance
          </h5>
        </div>
        <div class="card-body text-center">

          <!-- GANTI DENGAN GAMBAR ANDA -->
          <img src="/images/work-instruction-mtn.jpg" 
               class="img-fluid rounded shadow-sm mb-3"
               style="max-height:400px; object-fit:cover;">

          <p class="text-muted">
            Panduan prosedur preventive & corrective maintenance untuk menjaga performa mesin produksi.
          </p>

        </div>
      </div>
    </div>
  </section>

  <!-- Aktivitas Maintenance -->
  <section class="content mt-4 pb-5">
    <div class="container-fluid">

      <h4 class="font-weight-bold text-danger mb-3">
        Aktivitas Maintenance
      </h4>

      <div class="row">

        <!-- Foto 1 -->
        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <img src="/images/mtn-1.jpg" class="card-img-top" style="height:220px; object-fit:cover;">
            <div class="card-body">
              <h6 class="font-weight-bold">Preventive Maintenance</h6>
              <p class="text-muted small">
                Pemeriksaan rutin dan perawatan berkala untuk mencegah kerusakan mesin.
              </p>
            </div>
          </div>
        </div>

        <!-- Foto 2 -->
        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <img src="/images/mtn-2.jpg" class="card-img-top" style="height:220px; object-fit:cover;">
            <div class="card-body">
              <h6 class="font-weight-bold">Machine Repair</h6>
              <p class="text-muted small">
                Proses perbaikan mesin saat terjadi breakdown.
              </p>
            </div>
          </div>
        </div>

        <!-- Foto 3 -->
        <div class="col-md-4">
          <div class="card shadow-sm border-0">
            <img src="/images/mtn-3.jpg" class="card-img-top" style="height:220px; object-fit:cover;">
            <div class="card-body">
              <h6 class="font-weight-bold">Downtime Analysis</h6>
              <p class="text-muted small">
                Analisa penyebab gangguan untuk meningkatkan reliability mesin.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</div>

<%- include("../partials/footer") %>