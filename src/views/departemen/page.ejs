<style>
  .dashboard-box {
    background: #ffffff;
    border-radius: 18px;
    padding: 30px 20px;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(0,0,0,0.06);
    border: 1px solid #f1f1f1;
    height: 100%;
  }

  .dashboard-box:hover {
    transform: translateY(-6px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.12);
  }

  .dashboard-icon {
    width: 85px;
    height: 85px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: auto;
    margin-bottom: 18px;
    font-size: 34px;
  }

  .dashboard-title {
    font-size: 18px;
    font-weight: 700;
    color: #2c3e50;
    margin-bottom: 0;
  }

  .bg-soft-primary {
    background: rgba(0,123,255,0.12);
    color: #007bff;
  }

  .bg-soft-success {
    background: rgba(40,167,69,0.12);
    color: #28a745;
  }

  .bg-soft-warning {
    background: rgba(255,193,7,0.15);
    color: #f0ad00;
  }

  .bg-soft-danger {
    background: rgba(220,53,69,0.12);
    color: #dc3545;
  }

  .dashboard-link {
    text-decoration: none !important;
  }

  .dashboard-link:hover {
    text-decoration: none !important;
  }
</style>

